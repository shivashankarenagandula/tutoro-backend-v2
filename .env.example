# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to git — add it to .gitignore.

DJANGO_SECRET_KEY=replace-with-a-real-random-50-char-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres connection string
DATABASE_URL=postgres://tutoro_user:replace_me@localhost:5432/tutoro

# Comma-separated list of frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Once you integrate a payment gateway (Stage 2)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# Once you integrate WhatsApp/SMS notifications
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
